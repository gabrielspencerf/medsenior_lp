# ===========================================
# MedSênior LP – Variáveis de ambiente
# Copie para .env e preencha conforme o deploy.
# ===========================================

# --- Localização / Praça ---
# Deixe vazio para modo multi-cidade (usuário escolhe no modal).
# Preencha com o nome exato da praça (ex: Curitiba, Vitória) para travar o site em uma praça.
VITE_LOCATION=

# --- Typebot (chat/WhatsApp) ---
# ID do fluxo no Typebot. Se vazio, usa "medseniorbrasil".
# Ao clicar em uma praça, a variável utm_brasil é enviada automaticamente com o nome da cidade.
VITE_TYPEBOT_ID=medseniorbrasil

# --- Google Tag Manager ---
# ID do container GTM (ex: GTM-XXXXXX). Deixe vazio para não carregar GTM.
VITE_GTM_ID=

# --- Operador do site (identidade / conformidade) ---
# Nome e CNPJ de quem opera o site (corretora/revendedor). Aparecem no footer e em políticas.
# Se vazios, o footer usa "Revendedor autorizado BrasCare".
VITE_SITE_OPERATOR_NAME=
VITE_SITE_OPERATOR_CNPJ=

# --- Contato (opcional) ---
# E-mail e telefone para políticas e LGPD. Opcional.
VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=
